# Copy to .env and set your key before running.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-1.5-flash

# API service defaults
API_HOST=0.0.0.0
API_PORT=8011
LOG_LEVEL=INFO

# Optional: require x-api-key on /api/v1/jobs* endpoints.
BACKEND_API_KEY=

# Production hardening knobs
ALLOWED_HOSTS=*
CORS_ORIGINS=*
MAX_PARALLEL_JOBS=2
